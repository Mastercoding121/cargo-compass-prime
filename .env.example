# Appwrite Configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_DATABASE_ID=your-appwrite-database-id
APPWRITE_PRODUCTS_COLLECTION_ID=your-appwrite-products-collection-id
APPWRITE_ORDERS_COLLECTION_ID=your-appwrite-orders-collection-id
APPWRITE_PENDING_QUEUE_COLLECTION_ID=your-appwrite-pending-queue-collection-id
APPWRITE_LOGS_COLLECTION_ID=your-appwrite-logs-collection-id

# Vite Client Env Vars (must start with VITE_)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-appwrite-project-id
VITE_APPWRITE_DATABASE_ID=your-appwrite-database-id

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Marketplace API Configuration
PARSE_API_KEY=your_parse_bot_api_key_here
MARKETPLACE_API_KEY=your_marketplace_api_key_here

# Proxy Configuration (Optional)
SCRAPER_PROXY_URL=
